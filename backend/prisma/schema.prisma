model User {
  id          String         @id @default(cuid())
  username    String         @unique
  displayName String?
  adminToken  String         // bcrypt-hashed
  createdAt   DateTime       @default(now())
  visits      CountryVisit[]
}

model CountryVisit {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  countryCode   String    // ISO 3166-1 alpha-3 (e.g., "FRA")
  status        Status
  visitDates    Json?     // [{ start: "2023-06-01", end: "2023-06-10", label?: "Summer trip" }]
  rating        Int?      // 1-5
  notes         String?
  aiItinerary   Json?     // Cached Claude response
  aiGeneratedAt DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  @@unique([userId, countryCode])
}

enum Status {
  VISITED
  PLANNED
  WISHLIST
}
